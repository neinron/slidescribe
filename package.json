{
  "name": "slidescribe",
  "version": "1.0.0",
  "description": "Electron app for converting lecture PDFs into Markdown with Gemini vision models.",
  "productName": "SlideScribe",
  "author": "Jaron Schurer",
  "main": "electron/main.js",
  "scripts": {
    "setup": "sh ./scripts/setup.sh",
    "build:icon": "sh ./scripts/build-macos-icon.sh",
    "start": "node electron/start.js",
    "dev": "nodemon",
    "electron:package": "electron-forge package",
    "package": "node scripts/package.js",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.jaronschurer.slidescribe",
    "productName": "SlideScribe",
    "files": [
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      },
      {
        "from": "venv",
        "to": "venv"
      }
    ],
    "directories": {
      "output": "dist-electron"
    },
    "mac": {
      "icon": "assets/icon.icns"
    }
  },
  "dependencies": {
    "katex": "^0.16.25",
    "marked": "^16.3.0",
    "pdfjs-dist": "^5.4.149"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "nodemon": "^3.1.10"
  }
}
